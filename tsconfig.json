{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "index.ts",
    "api.ts",
    "types.ts",
    "dataframe/**/*",
    "columnExpressions/**/*",
    "datatypes/**/*",
    "utils/**/*"
  ],
  "exclude": [
    "node_modules",
    "_tests/**/*",
    "dist"
  ]
}
