{
  "name": "framescript",
  "version": "1.4.0",
  "description": "A zero-dependency, high-performance, expression-based DataFrame library for TypeScript/JavaScript.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && esbuild src/index.ts --bundle --minify --outfile=dist/index.js --platform=node",
    "test": "tsx _tests/run_all_project_tests.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dataframe",
    "polars",
    "pandas",
    "data-analysis",
    "typescript",
    "columnar",
    "data-science",
    "zero-dependency"
  ],
  "author": "Trent Morris",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsx": "^4.15.5",
    "@types/node": "^20.14.2"
  }
}
